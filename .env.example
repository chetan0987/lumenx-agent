# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LumenX Platform ───────────────────────────────────────────────────────────
LUMENX_BASE_URL=https://lumenx-demo.up.railway.app
LUMENX_ADMIN_TOKEN=lmx_...

# ── Agent behaviour ───────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.80        # auto-send when model score >= this value
POLL_INTERVAL_SECONDS=5          # how often to check for new inbox messages
WIKI_TOP_K=5                     # KB chunks to inject into each prompt

# ── Confidence Net training ───────────────────────────────────────────────────
CONFIDENCE_MIN_SAMPLES=10        # min feedback entries before MLP trains (use 200+ in prod)

# ── Server (Docker / Railway) ─────────────────────────────────────────────────
PORT=8001                        # Railway overrides this automatically
